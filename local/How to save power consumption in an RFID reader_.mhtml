  0% { transform: none; }
  20% { transform: rotateZ(-90deg) rotateY(180deg); }
  40% { background: chocolate; transform: none; }
  60% { background: white; }
  80% { background: cornflowerblue; }
  90% { transform: none; background: rgb(34, 34, 34); }
}

@keyframes rot {=20
