@charset "utf-8";

.pf-widget, .pf-widget * { box-sizing: border-box; }

.pf-widget, .pf-widget .pf-widget-body { color: rgb(136, 136, 136); }

.pf-widget .pf-widget-btn, .pf-widget .pf-widget-close, .pf-widget a { text=
-decoration: none; cursor: pointer; }

.pf-hidden, .pf-widget .pf-content-unit, .pf-widget .pf-widget-img { displa=
y: none; }

.pf-widget.error, .pf-widget.success { transition: opacity 0.3s; }

.pf-box-shadow { box-shadow: rgba(0, 0, 0, 0.5) 0px 4px 4px -4px; }

.pf-widget { z-index: 9999; font-family: "Helvetica Neue", Helvetica, Arial=
, sans-serif; visibility: hidden; opacity: 0; text-align: left; background-=
color: rgb(241, 241, 241); font-size: 15px; }

.pf-widget .pf-widget-footer { font-size: 12px; margin-top: 10px; }

@media screen and (max-width: 736px), screen and (max-height: 640px) {
  .pf-widget.pf-mobile-hide { display: none; }
}

.pf-widget * { text-shadow: none; }

.pf-widget a, .pf-widget h2, .pf-widget input, .pf-widget p, .pf-widget sel=
ect, .pf-widget textarea { margin: 0px; padding: 0px; border: 0px; backgrou=
nd: 0px 0px; }

.pf-widget .pf-widget-headline { margin: 0px 0px 10px; color: rgb(68, 68, 6=
8); font-weight: 500; }

.pf-widget input[type=3D"text"], .pf-widget input[type=3D"email"], .pf-widg=
et input[type=3D"date"], .pf-widget select, .pf-widget textarea { font-fami=
ly: "Helvetica Neue", Helvetica, Arial, sans-serif; border-radius: 3px; fon=
t-size: 14px; width: 100%; padding: 10px 15px; background: rgb(255, 255, 25=
5); box-shadow: rgba(0, 0, 0, 0.2) 0px 1px 1px inset; position: relative; b=
ox-sizing: border-box; }

.pf-widget input[type=3D"text"]::-webkit-input-placeholder, .pf-widget inpu=
t[type=3D"email"]::-webkit-input-placeholder, .pf-widget input[type=3D"date=
"]::-webkit-input-placeholder, .pf-widget select::-webkit-input-placeholder=
, .pf-widget textarea::-webkit-input-placeholder { color: rgb(169, 169, 169=
); }

.pf-widget select { appearance: none; }

.pf-widget select.default { color: rgb(169, 169, 169); }

.pf-widget form:not(.pf-custom-form) input[type=3D"text"], .pf-widget form:=
not(.pf-custom-form) input[type=3D"email"], .pf-widget form:not(.pf-custom-=
form) select, .pf-widget form:not(.pf-custom-form) textarea { margin-bottom=
: 10px; }

.pf-widget form:not(.pf-custom-form) [data-required=3D"true"].bad-validatio=
n, .pf-widget form:not(.pf-custom-form) [data-required=3D"true"].invalid, .=
pf-widget form:not(.pf-custom-form) [data-validate=3D"true"].bad-validation=
, .pf-widget form:not(.pf-custom-form) [data-validate=3D"true"].invalid { b=
order: 1px solid rgb(241, 38, 38); }

.pf-widget input[type=3D"text"], .pf-widget input[type=3D"email"], .pf-widg=
et input[type=3D"date"], .pf-widget select { clear: both; }

.pf-widget textarea { resize: none; }

.pf-widget .pf-widget-img { border-radius: 50%; }

.pf-widget .pf-widget-message { line-height: 1.5; font-size: 15px; }

.pf-widget .pf-widget-btn { display: inline-block; padding: 0px 26px; line-=
height: 35px; font-size: 14px; border-radius: 5px; border: 0px; margin-bott=
om: 2px; }

.pf-widget .error-state, .pf-widget .success-state, .pf-widget.success .pf-=
widget-headline, .pf-widget.success .pf-widget-message, .pf-widget.success =
form { display: none; }

.pf-widget .pf-widget-btn.pf-widget-ok { box-shadow: rgba(0, 0, 0, 0.2) 0px=
 1px 1px; color: rgb(68, 68, 68); background-color: rgb(255, 255, 255); }

.pf-widget .pf-widget-btn.pf-widget-cancel { color: rgb(187, 187, 187); bac=
kground-color: rgb(241, 241, 241); }

.pf-widget .pf-widget-btn + .pf-widget-btn { margin-left: 5px; margin-right=
: 5px; }

.pf-widget .pf-widget-close { font-size: 24px; position: absolute; top: 4px=
; line-height: 1; right: 0px; margin-right: 12px; color: rgb(187, 187, 187)=
; padding: 0px; background-color: transparent; border: 0px; }

.pf-widget.opened { visibility: visible; opacity: 1; }

.pf-widget .branding { position: relative; }

.pf-widget .branding svg { position: absolute; bottom: -25px; right: -25px;=
 fill: rgb(136, 136, 136); opacity: 0.25; width: 120px; }

@media screen and (max-width: 736px), screen and (max-height: 640px) {
