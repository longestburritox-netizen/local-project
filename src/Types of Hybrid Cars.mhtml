</li>
<li data-start=3D"1716" data-end=3D"1736">
<p data-start=3D"1718" data-end=3D"1736">VarioCam (Porsche)</p>
</li>
<li data-start=3D"1737" data-end=3D"1759">
<p data-start=3D"1739" data-end=3D"1759">CVVT (Hyundai / Kia)</p>
</li>
</ul>
<hr data-start=3D"1761" data-end=3D"1764">
